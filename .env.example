# ============================================================
# hackduke — environment variable reference
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# Supabase (required for screenshot storage and database)
# ------------------------------------------------------------
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_SCREENSHOT_BUCKET=

# ------------------------------------------------------------
# AI Provider
# Set VITE_AI_PROVIDER to "local" (default) or "openai"
# ------------------------------------------------------------
VITE_AI_PROVIDER=local

# Local MLX server (used when VITE_AI_PROVIDER=local)
# Run a compatible OpenAI-compatible server locally on this address
VITE_MLX_BASE_URL=http://127.0.0.1:8081
VITE_MLX_MODEL_ID=mlx-community/Qwen3.5-0.8B-MLX-8bit

# OpenAI (used when VITE_AI_PROVIDER=openai)
# WARNING: VITE_ variables are inlined into the browser bundle.
# Do not use a production API key here without a backend proxy.
VITE_OPENAI_API_KEY=
VITE_OPENAI_MODEL=

# ------------------------------------------------------------
# Debug
# Set to "true" to enable the in-app debug log overlay
# ------------------------------------------------------------
VITE_DEBUG=false
